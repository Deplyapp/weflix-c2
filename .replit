modules = ["nodejs-24"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "he-project/artifacts/tg-bot: CineBot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/mockup-sandbox: Component Preview Server"

[[workflows.workflow]]
name = "he-project/artifacts/tg-bot: CineBot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sh -c 'echo \"[CineBot] Waiting for API server (artifacts/api-server on port 8080)...\" && until curl -sf http://localhost:8080/api/healthz > /dev/null 2>&1; do sleep 2; done && echo \"[CineBot] API server ready — starting bot\" && cd he-project && API_BASE_URL=http://localhost:8080/api pnpm --filter @workspace/tg-bot run start'"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "artifacts/mockup-sandbox: Component Preview Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8000 BASE_PATH=/__mockup/ pnpm --filter @workspace/mockup-sandbox run dev"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "webview"
isCanvasWorkflow = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
VITE_BASE_URL = "https://api.themoviedb.org/3"
MOVIEBOX_BFF_SECRET = "76iRl07s0xSN9jqmEWAt79EBJZulIQIsV64FZr2O"
CF_H5_WORKER_URL = "https://h5-token-proxy.popcorntv-proxy.workers.dev/"
BFF_AUTH_TOKEN = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1aWQiOjE3MTY3NjczMDA2OTY1NTcwMzIsInV0cCI6MSwiZXhwIjoxNzgzODc0Mjk1LCJpYXQiOjE3NzYwOTc5OTV9.Q4_EpUhkYruee8Fu3MFZyAOdNsHpZYit2wpsFf9YpOM"

[userenv.production]
CF_STREAM_PROXY_URL = "https://weflix-stream-proxy.popcorntv-proxy.workers.dev/"
BFF_PROXY_URL = "https://weflix-bff-proxy.popcorntv-proxy.workers.dev"

[nix]
channel = "stable-25_05"
